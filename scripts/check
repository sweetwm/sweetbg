#!/usr/bin/env sh
set -eu

cd "$(CDPATH='' cd -- "$(dirname -- "$0")/.." && pwd)"

./scripts/format check

if [ -d build ]; then
	meson setup --reconfigure build --werror
else
	meson setup build --werror
fi

ninja -C build

if meson test -C build --list >/dev/null 2>&1; then
	meson test -C build --print-errorlogs
else
	printf 'No tests defined yet; skipping.\n'
fi
